    if bullet_intersects(past_state.hitbox):
        return True
    return Falsedef check_hit(shooter, target, shot_time):
    past_state = rewind(target, shot_time)

    if bullet_intersects(past_state.hitbox):
        return True
    return FalseLast 200ms of player positionsClient:
  I am at (x=10)

Server:
  You are actually at (x=8)

Client:
  Smooth correction appliedClient predicted position ≠ Server position
→ correction sentdef predict_movement(input, state):
    state.position += input.direction * state.speed
    return stateTICK_RATE = 60
