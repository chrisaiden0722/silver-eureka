using UnityEngine;

public class PlayerXP : NetworkBehaviour
{
    [SyncVar] public int xp = 0;
    [SyncVar] public int level = 1;

    public void AddXP(int amount)
    {
        if (!isServer) return;

        xp += amount;

        if (xp >= level * 500)
        {
            xp = 0;
            level++;
            RpcLevelUp(level);
        }
    }

    [ClientRpc]
    void RpcLevelUp(int newLevel)
    {
        Debug.Log("LEVEL UP! " + newLevel);
    }
}using UnityEngine;
using UnityEngine.UI;
using Mirror;
using System.Linq;

public class ScoreboardUI : MonoBehaviour
{
    public GameObject panel;
    public GameObject rowPrefab;
    public Transform content;

    void Update()
    {
        if (Input.GetKey(KeyCode.Tab))
        {
            panel.SetActive(true);
            UpdateBoard();
        }
        else
        {
            panel.SetActive(false);
        }
    }

    void UpdateBoard()
    {
        foreach (Transform child in content)
            Destroy(child.gameObject);

        var players = FindObjectsOfType<PlayerStats>()
            .OrderByDescending(p => p.kills);

        foreach (var p in players)
        {
            GameObject row = Instantiate(rowPrefab, content);

            row.GetComponent<Text>().text =
                p.name + "  K:" + p.kills + "  D:" + p.deaths;
        }
    }
}IEnumerator RemoveAfterTime(GameObject obj, float time)
{
    yield return new WaitForSeconds(time - 1f);

    CanvasGroup cg = obj.AddComponent<CanvasGroup>();

    float t = 0;
    while (t < 1)
    {
        t += Time.deltaTime;
