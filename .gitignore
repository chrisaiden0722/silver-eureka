def track_reaction(player_id, shot_time, target_seen_time):
    rt = shot_time - target_seen_time

    if player_id not in reaction_times:
        reaction_times[player_id] = []

    reaction_times[player_id].append(rt)

    avg_rt = sum(reaction_times[player_id][-20:]) / len(reaction_times[player_id][-20:])

    # human limit ~180-250ms average
    if avg_rt < 0.08:
        flag(player_id, "impossible_reaction_time")import random

aim_history = {}

def analyze_aim(player_id, hit_location, target_movement):
    """
    hit_location: where player aimed
    target_movement: how fast enemy was moving
    """

    if player_id not in aim_history:
        aim_history[player_id] = []

    aim_history[player_id].append({
        "target_speed": target_movement,
        "accuracy": hit_location
    })

    recent = aim_history[player_id][-20:]

    perfect_hits = sum(1 for h in recent if h["accuracy"] == "head")
    total = len(recent)

    accuracy = perfect_hits / total if total > 0 else 0

    # humans rarely sustain 90%+ headshot accuracy on moving targets
    if accuracy > 0.85 and total >= 15:
        flag(player_id, "aim_bot_suspected")import time
import math

player_states = {}

MAX_SPEED = 12.0  # units/sec

def check_speed(player_id, new_pos):
    now = time.time()

    if player_id not in player_states:
        player_states[player_id] = (new_pos, now)
        return True

    old_pos, old_time = player_states[player_id]
    dt = now - old_time

    dist = math.dist(old_pos, new_pos)
    speed = dist / dt if dt > 0 else 0

    player_states[player_id] = (new_pos, now)

    if speed > MAX_SPEED:
        flag(player_id, "speed_hack")
        return False

    return True[ Unity Client ]
