    for prefix, service_url in SERVICES.items():

        if path.startswith(prefix):

            async with httpx.AsyncClient() as client:
                return await client.post(
                    f"{service_url}{path}",
                    json=body
                )

    return {"error": "service not found"}import httpx

SERVICES = {
    "/auth": "http://auth-service:8001",
    "/matchmaking": "http://matchmaking-service:8002",
    "/game": "http://game-service:8003",
    "/leaderboard": "http://leaderboard-service:8004",
}import time
from collections import defaultdict

requests = defaultdict(list)

def rate_limit(ip: str):

    now = time.time()

    requests[ip].append(now)

    # keep last 10 seconds
    requests[ip] = [t for t in requests[ip] if now - t < 10]

    if len(requests[ip]) > 30:
        BLOCKED_IPS.add(ip)
        return False

    return Truefrom fastapi import Request

BLOCKED_IPS = set()

def verify_request(request: Request):

    ip = request.client.host

    if ip in BLOCKED_IPS:
        return False

    # basic header validation
    if "user-agent" not in request.headers:
        return False

    return Truefrom fastapi import FastAPI, Request
from app.gateway.router import route_request
from app.gateway.security import verify_request

app = FastAPI(title="API Gateway")

@app.middleware("http")
async def gateway_middleware(request: Request, call_next):

    # 1. SECURITY CHECK
    if not verify_request(request):
        return {"error": "blocked by gateway"}

    # 2. ROUTE REQUEST
    response = await call_next(request)

    return responseapp/
