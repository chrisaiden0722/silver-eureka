public class PlayerXP : NetworkBehaviour
{
    [SyncVar] public int xp = 0;
    [SyncVar] public int level = 1;

    public void AddXP(int amount)
    {
        if (!isServer) return;

        xp += amount;

        if (xp >= level * 500)
        {
            xp = 0;
            level++;
            RpcLevelUp(level);
        }
    }

    [ClientRpc]
    void RpcLevelUp(int newLevel)
    {
        Debug.Log("LEVEL UP! " + newLevel);
    }
