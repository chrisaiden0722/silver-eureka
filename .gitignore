public class FadeIn : MonoBehaviour
{
    CanvasGroup cg;

    void Start()
    {
        cg = GetComponent<CanvasGroup>();
        StartCoroutine(Fade());
    }

    IEnumerator Fade()
    {
        float t = 0;

        while (t < 1)
        {
            t += Time.deltaTime;
            cg.alpha = t;
            yield return null;
        }
    }
