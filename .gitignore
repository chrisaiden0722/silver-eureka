router = APIRouter(prefix="/anticheat")

flags = {}

@router.post("/flag")
def flag(player_id: str, reason: str):
    flags[player_id] = flags.get(player_id, 0) + 1

    if flags[player_id] > 5:
        return {"banned": True}

    return {"banned": False}from fastapi import APIRouter, WebSocket

router = APIRouter(prefix="/game")

matches = {}

@router.websocket("/ws/{match_id}")
async def game(ws: WebSocket, match_id: str):
    await ws.accept()

    if match_id not in matches:
        matches[match_id] = []

    matches[match_id].append(ws)

    while True:
        data = await ws.receive_json()

        # SERVER AUTHORITY (NO CLIENT TRUST)
        response = {
            "type": "ack",
            "data": data
        }

        await ws.send_json(response)from fastapi import APIRouter
from collections import deque

router = APIRouter(prefix="/matchmaking")

queue = deque()

@router.post("/join")
def join(player_id: str):
    queue.append(player_id)

    if len(queue) >= 2:
        return {
            "match": [queue.popleft(), queue.popleft()],
            "status": "started"
        }

    return {"status": "waiting"}from fastapi import APIRouter

router = APIRouter(prefix="/auth")

users = {}

@router.post("/register")
def register(username: str):
    users[username] = {"mmr": 1000, "banned": False}
    return {"status": "created"}

@router.post("/login")
def login(username: str):
    if username not in users:
        return {"error": "not found"}
    return {"token": username}from fastapi import APIRouter

